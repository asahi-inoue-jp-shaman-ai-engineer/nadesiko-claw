# エージェント.nako3 — Claude APIとのやり取り（ヤマトの頭脳）
会話履歴 = []

# ユーザーメッセージをヤマトに送って返答を得る
●（入力を）ヤマトクロウとは
    # ユーザーメッセージを履歴に追加
    ユーザー行 = {"role":"user","content":入力}
    会話履歴にユーザー行を配列プッシュ

    # Claude API呼び出し
    応答 = 会話履歴をAIコール

    # エラーチェック
    もし 「error」が 応答に辞書キー存在 ならば
        エラー内容 = 応答["error"]
        もし 「message」が エラー内容に辞書キー存在 ならば
            それは 「❌ APIエラー: 」 & エラー内容["message"]。戻る。
        ここまで
        それは 「❌ APIエラーが発生しました」。戻る。
    ここまで

    # 返答テキストを取り出す（OpenAI/OpenRouter形式: choices[0].message.content）
    返答テキスト = ""
    エラー監視
        選択肢 = 応答["choices"]
        返答テキスト = 選択肢[0]["message"]["content"]
    エラーならば
        返答テキスト = 「❌ 応答の解析に失敗しました」
    ここまで

    # [MEMORY] タグと [CUSTOM] タグを抽出してクリーンな返答を作る
    抽出記憶リスト = []
    クリーン返答 = 返答テキスト
    カスタム抽出テキスト = ""
    JS実行(🌿
        const text = sys.__findVar('返答テキスト', '');
        const memories = [];
        const memRegex = /\[MEMORY\s+category="([^"]+)"\s+importance="(\d+)"\]([\s\S]*?)\[\/MEMORY\]/g;
        let match;
        while ((match = memRegex.exec(text)) !== null) {
            memories.push({
                category: match[1],
                importance: parseInt(match[2]),
                content: match[3].trim()
            });
        }
        let cleaned = text.replace(memRegex, '');
        let customText = '';
        const customRegex = /\[CUSTOM\]([\s\S]*?)\[\/CUSTOM\]/g;
        let customMatch;
        while ((customMatch = customRegex.exec(text)) !== null) {
            customText += customMatch[1].trim() + '\n';
        }
        cleaned = cleaned.replace(/\[CUSTOM\][\s\S]*?\[\/CUSTOM\]/g, '').trim();
        sys.__setSysVar('抽出記憶リスト', memories);
        sys.__setSysVar('クリーン返答', cleaned);
        sys.__setSysVar('カスタム抽出テキスト', customText.trim());
    🌿)

    # [MEMORY] タグの内容をSupabaseに保存
    記憶件数 = 抽出記憶リスト の配列要素数
    もし 記憶件数 > 0 ならば
        # supabase_save.mjs が存在するか確認してから保存
        存在確認 = 「./supabase_save.mjs」が存在
        もし 存在確認 ならば
            保存データ = {"table":"yamato_memories","records":抽出記憶リスト}
            保存データをJSONエンコードを「./tmp_save.json」に保存
            「node ./supabase_save.mjs」を起動待機
        ここまで
    ここまで

    # [CUSTOM] タグの内容をカスタム.md に追記
    カスタム長さ = カスタム抽出テキスト の文字数
    もし カスタム長さ > 0 ならば
        既存カスタム = ""
        エラー監視
            既存カスタム = 「./カスタム.md」を読
        エラーならば
            既存カスタム = ""
        ここまで
        新カスタム内容 = 既存カスタム & 改行 & カスタム抽出テキスト
        新カスタム内容を「./カスタム.md」に保存
    ここまで

    # 履歴にはクリーンな返答を追加
    アシスタント行 = {"role":"assistant","content":クリーン返答}
    会話履歴にアシスタント行を配列プッシュ

    それは クリーン返答
ここまで

# Claude API呼び出し（api_call.mjsを起動待機で同期実行）
●（会話データを）AIコールとは
    システム = 設定["agent"]["identity"]
    モデル   = 設定["agent"]["model"]

    ボディ    = {"model":モデル,"max_tokens":4096,"system":システム,"messages":会話データ}
    ボディJSON = ボディをJSONエンコード

    # tmpファイルに書き出す
    ボディJSONを「./tmp_body.json」に保存

    # api_call.mjs を同期実行してstdoutをJSONとして受け取る
    応答文字列 = 「node ./api_call.mjs」を起動待機

    # 返答パース
    応答 = {}
    エラー監視
        応答 = 応答文字列をJSONデコード
    エラーならば
        エラー詳細 = {"message":"JSONデコード失敗"}
        応答 = {"error":エラー詳細}
    ここまで

    それは 応答
ここまで

「✅ エージェント（ヤマト）準備完了」と表示。
